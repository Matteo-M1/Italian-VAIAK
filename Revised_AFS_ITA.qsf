tem)","PasswordProtection":"No","AnonymizeResponse":"Yes","Password":"","RefererCheck":"No","RefererURL":"http:\/\/","UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":"","SurveyLinkCompletedMessageLibrary":"","ResponseSummary":"No","EOSRedirectURL":"https:\/\/unipadova.qualtrics.com\/jfe\/form\/SV_bsmnDcvX9Q4whzU?SURVEY_ID=${e:\/\/Field\/ResponseIDt?format=urlencode}","EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"true","ValidationMessageLibrary":null,"InactiveSurvey":"DefaultMessage","PartialDataCloseAfter":"LastActivity","ActiveResponseSet":null,"InactiveMessageLibrary":"","InactiveMessage":"","AvailableLanguages":{"IT":[]},"QuestionsPerPage":"10","SpellChecked":"1","":null,"PartialDeletion":null,"EOSMessage":null,"BallotBoxStuffingPreventionBehavior":null,"BallotBoxStuffingPreventionMessage":null,"BallotBoxStuffingPreventionMessageLibrary":null,"BallotBoxStuffingPreventionURL":null,"RecaptchaV3":"false","ConfirmStart":false,"AutoConfirmStart":false,"RelevantID":"false","RelevantIDLockoutPeriod":"+30 days","EOSMessageLibrary":null,"SurveyName":"Revised AFS (ITA)"}},{"SurveyID":"SV_0GOArm5n5XLNcQ6","Element":"SQ","PrimaryAttribute":"QID38","SecondaryAttribute":"\u00a0 Nella seguenze sezione siamo interessati alla conoscenza delle arti da parte delle persone \u2013 il","TertiaryAttribute":null,"Payload":{"QuestionText":"<div>&nbsp;<\/div>Nella seguenze sezione siamo interessati alla <strong>conoscenza delle arti <\/strong>da parte delle persone \u2013 il loro livello di conoscenza rispetto agli artisti, alle idee, ai concetti e alle tecniche del mondo dell\u2019arte.<br>Per ciascuno di questi si chiede di <strong>assegnare un punteggio<\/strong> in base a quanto si conosce il soggetto. Non ci sono risposte giuste o sbagliate.<br><div>&nbsp;<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 Nella seguenze sezione siamo interessati alla conoscenza delle arti da parte delle persone \u2013 il...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<div>ART KNOWLEDGE SURVEY<\/div><div><br><\/div><div>We're interested in people's knowledge of the arts---how much they know about different artists, ideas, concepts, and techniques in the world of art.<\/div><div><br><\/div><div>The following page has a list of 10 artists and terms in art history. For each one, please rate how much you know about it.<br><\/div><div><br><\/div><div>There are no right or wrong answers, and we appreciate your time and attention.<\/div>","DataExportTag":"AFS_1_Instructions","QuestionID":"QID38","QuestionJS":false}},{"SurveyID":"SV_0GOArm5n5XLNcQ6","Element":"SQ","PrimaryAttribute":"QID45","SecondaryAttribute":"Per favore indica quanto conosci il seguente artista o termine","TertiaryAttribute":null,"Payload":{"QuestionText":"Per favore indica quanto conosci il seguente artista o termine","DefaultChoices":false,"QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"MobileFirst":true,"RepeatHeaders":"none","WhiteSpace":"OFF"},"QuestionDescription":"Per favore indica quanto conosci il seguente artista o termine","Choices":{"18":{"Display":"John Singer Sargent"},"19":{"Display":"Gerhard Richter"},"24":{"Display":"Jackson Pollock"},"25":{"Display":"Piet Mondrian"},"71":{"Display":"Frida Kahlo"},"77":{"Display":"Georgia O\u2019Keeffe"},"95":{"Display":"Alessandro Botticelli"},"99":{"Display":"Salvador Dal\u00ed"},"112":{"Display":"Jean-Michel Basquiat"},"124":{"Display":"Claude Monet"},"128":{"Display":"Vincent van Gogh"},"129":{"Display":"Marcel Duchamp"},"130":{"Display":"Georges Braque"},"131":{"Display":"Eug\u00e8ne De